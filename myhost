#!/data/data/com.termux/files/usr/bin/bash

clear

while true
do

echo ""
echo "===================================="
echo "          Shahadat Host"
echo "===================================="
echo ""
echo "1  Start PHP Server"
echo "2  Stop Server"
echo "3  Database Manager"
echo "4  File Manager"
echo "5  Change PHP Run Path"
echo "6  Server Status"
echo "0  Exit"
echo ""
echo "===================================="
echo ""

read -p "Choose Option: " option

case $option in

1)
clear

echo "Start PHP Server"
echo ""

# Default path = current directory
read -p "Enter File Path [default: current]: " path

if [ -z "$path" ]; then
path=$(pwd)
fi

# Default port = 8080
read -p "Enter Port [default:8080]: " port

if [ -z "$port" ]; then
port=8080
fi

echo ""
echo "Checking project files..."

# Auto detect index file
if [ -f "$path/index.php" ]; then
index="index.php"
elif [ -f "$path/index.html" ]; then
index="index.html"
else
index=""
fi

echo ""
echo "Starting MariaDB..."
mysqld_safe > /dev/null 2>&1 &

sleep 2

echo ""
echo "===================================="
echo "Server Started Successfully"
echo "===================================="
echo ""
echo "Project Path : $path"
echo "Port         : $port"
echo ""

if [ -n "$index" ]; then
echo "▶ Hosted at: http://localhost:$port/$index"
else
echo "▶ Hosted at: http://localhost:$port"
fi

echo ""
echo "Press CTRL + C to stop server"
echo ""

php -S localhost:$port -t "$path"
;;

2)
pkill mysqld
pkill php
echo "Server stopped"
;;

3)
bash db.sh
;;

4)
bash filemanager.sh
;;

5)
echo "Feature reserved for future version"
;;

6)
clear
echo "Server Status"
echo "-------------"

ps aux | grep mysqld | grep -v grep > /dev/null
if [ $? -eq 0 ]; then
echo "MariaDB: Running"
else
echo "MariaDB: Stopped"
fi

ps aux | grep php | grep -v grep > /dev/null
if [ $? -eq 0 ]; then
echo "PHP Server: Running"
else
echo "PHP Server: Stopped"
fi
;;

0)
exit
;;

*)
echo "Invalid option"
;;

esac

done
